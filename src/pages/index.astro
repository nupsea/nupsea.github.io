---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// Get latest 3 blog posts
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 3);

const talks = [
  {
    title: "Building an AI Agent: Bookmate",
    event: "Tech Talk",
    date: "2025",
    link: "https://youtu.be/ELKLjiJHgzM?si=hfVWZ9d0mOaokqLt"
  }
];

const featuredProjects = [
  {
    name: "Doc-Mate",
    description: "Intelligent document assistant powered by GenAI and RAG.",
    link: "https://github.com/nupsea/doc-mate"
  },
  {
    name: "Content-Pal",
    description: "RAG-style streaming content assistant for films and availability.",
    link: "https://github.com/nupsea/content-pal"
  },
  {
    name: "Flink Score Publisher",
    description: "Real-time T20 match updates from Flink to Redis.",
    link: "https://github.com/nupsea/flink-score-pub"
  }
];
---

<Layout>
  <!-- Hero Section -->
  <div class="relative overflow-hidden py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl lg:mx-0">
        <h1 class="text-5xl font-extrabold tracking-tight text-white sm:text-7xl font-['Plus_Jakarta_Sans',sans-serif]">
          Anup Sethuram
        </h1>
        <p class="mt-6 text-xl leading-8 text-slate-400">
          Building scalable data systems and exploring Generative AI workflows.
        </p>
        <div class="mt-10 flex items-center gap-x-6">
          <a
            href="/projects"
            class="rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-[0_0_20px_rgba(99,102,241,0.2)] hover:bg-indigo-500 hover:shadow-[0_0_25px_rgba(99,102,241,0.3)] transition-all focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600"
          >
            My Projects
          </a>
          <a href="/blog" class="text-sm font-medium leading-6 text-slate-300 hover:text-white transition-colors">
            Read Blog <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Content Grid (Blogs & Talks) -->
  <div class="bg-[#080c16] border-y border-slate-900/60 py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        
        <!-- Recent Blogs -->
        <div>
          <div class="flex items-center justify-between mb-8">
            <h2 class="text-2xl font-bold tracking-tight text-white font-['Plus_Jakarta_Sans',sans-serif]">Recent Writing</h2>
            <a href="/blog" class="text-sm font-semibold text-indigo-400 hover:text-indigo-300 transition-colors">View all &rarr;</a>
          </div>
          <div class="space-y-8">
            {posts.map((post) => (
              <article class="relative isolate flex flex-col gap-2 group">
                <div>
                  <div class="flex items-center gap-x-4 text-xs font-mono text-slate-500">
                    <time datetime={post.data.pubDate.toISOString()}>
                      {new Date(post.data.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                    </time>
                  </div>
                  <h3 class="mt-2 text-lg font-bold leading-6 text-white group-hover:text-indigo-400 transition-colors font-['Plus_Jakarta_Sans',sans-serif]">
                    <a href={`/blog/${post.slug}/`}>
                      <span class="absolute inset-0"></span>
                      {post.data.title}
                    </a>
                  </h3>
                  <p class="mt-2 text-sm leading-6 text-slate-400">{post.data.description}</p>
                </div>
              </article>
            ))}
          </div>
        </div>

        <!-- Recent Talks -->
        <div>
          <div class="flex items-center justify-between mb-8">
            <h2 class="text-2xl font-bold tracking-tight text-white font-['Plus_Jakarta_Sans',sans-serif]">Talks</h2>
            <a href="/talks" class="text-sm font-semibold text-indigo-400 hover:text-indigo-300 transition-colors">View all &rarr;</a>
          </div>
          <div class="space-y-8">
            {talks.map((talk) => (
              <div class="relative bg-[#111625] p-6 rounded-xl border border-slate-800/80 shadow-sm hover:border-slate-700/80 hover:shadow-[0_4px_20px_rgba(0,0,0,0.3)] transition-all duration-300 group">
                <h3 class="text-lg font-bold text-white group-hover:text-indigo-400 transition-colors font-['Plus_Jakarta_Sans',sans-serif]">
                  <a href={talk.link} target="_blank">
                    <span class="absolute inset-0"></span>
                    {talk.title}
                  </a>
                </h3>
                <div class="mt-2 flex items-center text-sm font-mono text-slate-500">
                  <span class="font-medium text-slate-300 mr-2">{talk.event}</span>
                  &bull;
                  <span class="ml-2">{talk.date}</span>
                </div>
                <div class="mt-4 flex items-center text-sm font-medium text-indigo-400 group-hover:text-indigo-300 transition-colors group/link">
                  Watch Video 
                  <svg class="ml-1 w-4 h-4 transform group-hover/link:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- Featured Projects Section -->
  <div class="py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl lg:mx-0">
        <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl font-['Plus_Jakarta_Sans',sans-serif]">Featured Projects</h2>
        <p class="mt-2 text-lg leading-8 text-slate-400">
          A glimpse into some of my recent work.
        </p>
      </div>
      <div class="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-x-8 gap-y-12 lg:mx-0 lg:max-w-none lg:grid-cols-3">
        {featuredProjects.map((project) => (
          <article class="flex flex-col items-start justify-between bg-[#111625] border border-slate-800/80 p-8 rounded-xl hover:border-slate-700/80 hover:shadow-[0_4px_25px_rgba(99,102,241,0.05)] transition-all duration-300 group min-h-[200px]">
            <div class="w-full">
              <h3 class="text-xl font-bold leading-6 text-white group-hover:text-indigo-400 transition-colors font-['Plus_Jakarta_Sans',sans-serif]">
                <a href={project.link} target="_blank">
                  {project.name}
                </a>
              </h3>
              <p class="mt-4 text-sm leading-6 text-slate-400">{project.description}</p>
            </div>
            <div class="mt-6 pt-4 border-t border-slate-900/60 w-full">
              <a href={project.link} target="_blank" class="inline-flex items-center text-sm font-medium text-indigo-400 hover:text-indigo-300 group/link">
                View Project
                <svg class="ml-1 w-4 h-4 transform group-hover/link:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>
      <div class="mt-12">
        <a href="/projects" class="text-sm font-semibold leading-6 text-indigo-400 hover:text-indigo-300 transition-colors">
          View all projects <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </div>
</Layout>