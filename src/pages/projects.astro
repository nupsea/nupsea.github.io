---
import Layout from '../layouts/Layout.astro';

const projectGroups = [
  {
    id: "genai",
    title: "GenAI Projects",
    description: "Retrieval-Augmented Generation (RAG) based assistants and Agentic workflows.",
    projects: [
      {
        name: "Headwater",
        description: "An advisory data platform that automates schema discovery, profiling, and documentation, generating SQL models and quality contracts for human review.",
        link: "https://github.com/nupsea/headwater"
      },
      {
        name: "Luminary",
        description: "A local-first active learning cockpit that combines a document reader, cited Q&A (RAG), AI-generated flashcards scheduled using the FSRS algorithm, and markdown notes.",
        link: "https://github.com/nupsea/luminary"
      },
      {
        name: "Fly-O-Myte",
        description: "The smart travel expense optimizer for Australian families. Tracks trips, builds price history, and gives clear booking advice.",
        link: "https://github.com/nupsea/fly-o-myte"
      },
      {
        name: "Doc-Mate",
        description: "Intelligent document assistant powered by GenAI and RAG.",
        link: "https://github.com/nupsea/doc-mate"
      },
      {
        name: "Content Pal",
        description: "Streaming media content assistant using RAG for hybrid search and recommendations.",
        link: "https://github.com/nupsea/content-pal"
      }
    ]
  },
  {
    id: "mlde",
    title: "ML & Data Engineering",
    description: "Machine learning models and data engineering toolkits.",
    projects: [
      {
        name: "dkit",
        description: "A data engineer's toolkit for schema inference, data profiling, SQL execution, validation, and pipeline scaffolding.",
        link: "https://github.com/nupsea/dkit"
      },
      {
        name: "Chase Prediction",
        description: "Prediction model to determine the chances of winning an IPL chase based on match data.",
        link: "https://github.com/nupsea/mlzc-ipl-pred"
      },
      {
        name: "PyFlink Score Publisher",
        description: "Real-time T20 match score publisher for Chase Prediction, using Apache PyFlink.",
        link: "https://github.com/nupsea/cric-chase-pred"
      },
      {
        name: "Flink Score Publisher",
        description: "Real-time T20 match score publisher for Chase Prediction, using Apache Flink (Java).",
        link: "https://github.com/nupsea/flink-score-pub"
      },
      {
        name: "Movie Rating Prediction",
        description: "Machine learning model to predict movie ratings based on reviews and genre.",
        link: "https://github.com/nupsea/mlzc-movie-pred"
      }
    ]
  }
];
---

<Layout>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <header class="mb-20 text-center">
      <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl font-['Plus_Jakarta_Sans',sans-serif]">
        Data & AI Projects
      </h1>
      <p class="mt-5 max-w-xl mx-auto text-lg text-slate-400">
        A curated collection of my work in machine learning, generative AI, and data engineering.
      </p>
    </header>

    <div class="space-y-24">
      {projectGroups.map((group) => (
        <section class="relative">
          <div class="mb-10 flex items-center gap-3 pb-4 border-b border-slate-900">
            {group.id === 'genai' ? (
              <svg class="w-8 h-8 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
              </svg>
            ) : (
              <svg class="w-8 h-8 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" />
              </svg>
            )}
            <div>
              <h2 class="text-2xl font-bold tracking-tight text-white font-['Plus_Jakarta_Sans',sans-serif]">{group.title}</h2>
              <p class="mt-1 text-sm text-slate-400">{group.description}</p>
            </div>
          </div>
          <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
            {group.projects.map((project) => (
              <div class="group relative bg-[#111625] border border-slate-800/80 rounded-xl p-8 shadow-sm hover:border-slate-700/80 hover:shadow-[0_4px_25px_rgba(99,102,241,0.05)] transition-all duration-300 flex flex-col justify-between min-h-[220px]">
                <div>
                  <h3 class="text-xl font-bold text-white group-hover:text-indigo-400 transition-colors font-['Plus_Jakarta_Sans',sans-serif]">
                    {project.name}
                  </h3>
                  <p class="mt-4 text-slate-400 leading-relaxed text-sm">
                    {project.description}
                  </p>
                </div>
                <div class="mt-8 pt-4 border-t border-slate-900/60">
                  <a
                    href={project.link}
                    target="_blank"
                    class="inline-flex items-center text-sm font-medium text-indigo-400 hover:text-indigo-300 transition-colors group/link"
                  >
                    View on GitHub
                    <svg class="ml-1.5 w-4 h-4 transform group-hover/link:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                    </svg>
                  </a>
                </div>
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>
</Layout>
